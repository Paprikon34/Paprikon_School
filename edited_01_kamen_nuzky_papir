# Nastavení logování
logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')

# Funkce pro načítání a tvorbu náhradních povrchů
def create_surface(width, height):
    return pygame.Surface((width, height))

# Funkce pro bezpečné načítání assetů s fallbacky
def load_asset(path):
    try:
        return pygame.image.load(path)
    except Exception as e:
        logging.warning(f"Chyba při načítání assetu: {e}")
        return create_surface(1, 1)

# Funkce pro načítání a tvorbu náhradních povrchů
def load_font(path):
    try:
        return pygame.font.Font(path, 24)
    except Exception as e:
        logging.warning(f"Chyba při načítání fontu: {e}")
        return create_surface(1, 1)

# Funkce pro bezpečné načítání assetů s fallbacky
def load_assets():
    assets = {}
    for file in os.listdir("assets"):
        path = os.path.join("assets", file)
        assets[file] = load_asset(path)
    return assets

# Funkce pro načítání a tvorbu náhradních povrchů
def create_game_surface(width, height):
    return create_surface(width, height)

# Funkce pro načítání a tvorbu náhradních povrchů
def create_game_font():
    return load_font("font.ttf")

# Funkce pro bezpečné načítání assetů s fallbacky
def load_game_assets():
    return load_assets()

# Funkce pro načítání a tvorbu náhradních povrchů
def load_game_font():
    return create_game_font()

